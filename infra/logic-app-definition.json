{
  "definition": {
    "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {},
    "triggers": {
      "manual": {
        "type": "Request",
        "kind": "Http",
        "inputs": {
          "schema": {
            "type": "object",
            "properties": {
              "userId": { "type": "string" }
            },
            "required": ["userId"]
          }
        }
      }
    },
    "actions": {
      "Validate_Input": {
        "type": "If",
        "expression": {
          "not": {
            "equals": [ "@{coalesce(triggerBody()?['userId'], '')}", "" ]
          }
        },
        "actions": {
          "Create_TAP": {
            "type": "Http",
            "inputs": {
              "method": "POST",
              "uri": "https://graph.microsoft.com/v1.0/users/@{triggerBody()?['userId']}/authentication/temporaryAccessPassMethods",
              "headers": { "Content-Type": "application/json" },
              "body": {
                "lifetimeInMinutes": 60,
                "isUsableOnce": true
              },
              "authentication": {
                "type": "ManagedServiceIdentity",
                "audience": "https://graph.microsoft.com"
              }
            }
          },
          "Response_Success": {
            "type": "Response",
            "runAfter": { "Create_TAP": ["Succeeded"] },
            "inputs": {
              "statusCode": 200,
              "headers": {
                "Content-Type": "application/json"
              },
              "body": {
                "success": true,
                "temporaryAccessPass": "@{body('Create_TAP')['temporaryAccessPass']}",
                "lifetimeInMinutes": "@{body('Create_TAP')['lifetimeInMinutes']}",
                "startDateTime": "@{body('Create_TAP')['startDateTime']}",
                "isUsableOnce": "@{body('Create_TAP')['isUsableOnce']}"
              }
            }
          },
          "Response_Graph_Error": {
            "type": "Response",
            "runAfter": { "Create_TAP": ["Failed", "TimedOut"] },
            "inputs": {
              "statusCode": 400,
              "headers": {
                "Content-Type": "application/json"
              },
              "body": {
                "success": false,
                "error": "Failed to create TAP. You may already have an active pass, or the account is not eligible. Check Entra ID audit logs for details."
              }
            }
          }
        },
        "else": {
          "actions": {
            "Response_Validation_Error": {
              "type": "Response",
              "inputs": {
                  "statusCode": 400,
                "headers": {
                  "Content-Type": "application/json"
                },
                "body": {
                  "success": false,
                    "error": "Invalid request: userId is required."
                }
              }
            }
          }
        }
      }
    },
    "outputs": {}
  },
  "parameters": {}
}
